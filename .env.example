# ── Coinbase Advanced Trade ──────────────────────────────────────────────────
# Create API keys at: https://www.coinbase.com/settings/api
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_API_SECRET=your_coinbase_api_secret_here

# ── OANDA v20 ────────────────────────────────────────────────────────────────
# Create API token at: https://www.oanda.com/account/tpa/personal_token
OANDA_ACCOUNT_ID=your_oanda_account_id_here
OANDA_API_TOKEN=your_oanda_api_token_here
# Use "practice" for paper trading, "live" for real money
OANDA_ENVIRONMENT=practice

# ── General Bot Settings ─────────────────────────────────────────────────────
# How often the signal engine refreshes (seconds)
SIGNAL_INTERVAL_SECONDS=60
# Minimum confidence score (0.0 – 1.0) required before placing a trade
MIN_CONFIDENCE=0.65
# Maximum total exposure across all brokers (USD)
MAX_TOTAL_EXPOSURE_USD=1000.0
# Set to "true" to run in paper/dry-run mode even with live credentials
PAPER_MODE=true

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
